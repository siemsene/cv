---
import Portrait from './Portrait.astro';
import { cv, SECTIONS } from '../data/cv';
const { profile, metrics } = cv;

const fmt = (n?: number) => (n == null ? '—' : n.toLocaleString('en-US'));
const stats = [
  { label: 'Citations', value: fmt(metrics.cited_by_count) },
  { label: 'h-index', value: fmt(metrics.h_index) },
  { label: 'i10-index', value: fmt(metrics.i10_index) },
];
---

<aside
  class="lg:sticky lg:top-0 lg:flex lg:h-screen lg:max-h-screen lg:flex-col lg:py-12"
>
  <div class="sidebar-scroll lg:min-h-0 lg:flex-1 lg:overflow-y-auto lg:pr-3">
    <!-- Identity -->
    <div class="reveal" style="--d:0ms">
      <div class="mb-5">
        <Portrait />
      </div>
      <a href="#about" class="group inline-block">
        <h1
          class="font-display text-[2.6rem] font-medium leading-[0.98] tracking-[-0.02em] text-ink sm:text-5xl"
          style="font-optical-sizing:auto"
        >
          {profile.name}
        </h1>
      </a>
      <p class="mt-3 max-w-sm font-serif text-[1.05rem] leading-snug text-ink-soft">
        {profile.title}
      </p>
      <p class="mt-1 text-sm text-ink-faint">
        {profile.affiliation}
      </p>
      <p class="text-sm text-ink-faint">{profile.location}</p>
    </div>

    <!-- Metrics -->
    <div class="reveal mt-7 flex gap-6 border-y border-line py-4" style="--d:90ms">
      {stats.map((s) => (
        <div>
          <div class="font-display text-2xl font-medium text-accent">
            {s.value}
          </div>
          <div class="mt-0.5 text-[0.68rem] uppercase tracking-[0.12em] text-ink-faint">
            {s.label}
          </div>
        </div>
      ))}
    </div>
    <p class="reveal mt-2 text-[0.66rem] text-ink-faint" style="--d:90ms">
      Live from OpenAlex
    </p>

    <!-- Download -->
    <a
      href="/cv.pdf"
      class="reveal group mt-6 inline-flex w-fit items-center gap-2 rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:bg-accent"
      style="--d:160ms"
    >
      <svg class="h-4 w-4 transition-transform group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16" />
      </svg>
      Download PDF
    </a>

    <!-- Section nav (desktop) -->
    <nav class="reveal mt-10 hidden lg:block" style="--d:240ms" aria-label="Sections">
      <ul class="space-y-1.5">
        {SECTIONS.map((s) => (
          <li>
            <a
              href={`#${s.id}`}
              class="nav-link group flex items-center gap-3 text-sm text-ink-faint transition-colors hover:text-ink"
              data-section={s.id}
            >
              <span class="nav-dot h-1.5 w-1.5 scale-50 rounded-full bg-line transition-all"></span>
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Contact links -->
    <div class="reveal mt-8 flex flex-wrap gap-x-4 gap-y-1.5 text-sm text-ink-soft" style="--d:320ms">
      {profile.email && (
        <a class="link-underline" href={`mailto:${profile.email}`}>Email</a>
      )}
      {profile.links.map((l) => (
        <a class="link-underline" href={l.url} target="_blank" rel="noopener">{l.label}</a>
      ))}
    </div>
  </div>
</aside>
