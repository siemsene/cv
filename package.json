{
  "name": "siemsen-cv",
  "type": "module",
  "version": "1.0.0",
  "description": "Enno Siemsen academic CV — website + PDF from a single data source",
  "scripts": {
    "fetch": "node scripts/fetch-openalex.mjs",
    "data": "node scripts/build-data.mjs",
    "pdf": "node scripts/build-pdf.mjs",
    "predev": "node scripts/build-data.mjs",
    "dev": "astro dev",
    "prebuild": "npm run fetch && npm run data && npm run pdf",
    "build": "astro build",
    "preview": "astro preview",
    "dois": "node scripts/dump-dois.mjs"
  },
  "dependencies": {
    "astro": "^6.4.4",
    "js-yaml": "^4.2.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0"
  }
}
